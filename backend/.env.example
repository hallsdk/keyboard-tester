# --- Copy this file to ".env" on the server and fill real values ---

# Server listen address
LISTEN_ADDR=:3030

# JWT signing secret. Generate with:  openssl rand -hex 32
JWT_SECRET=please-change-me-to-a-long-random-string

# Initial super-admin account. The container will create/refresh this user
# every start. After the first successful start you MAY clear these values
# (the user will continue to exist, but its password won't be re-forced).
SUPER_ADMIN_USER=root
SUPER_ADMIN_PASS=change-me-on-first-boot
